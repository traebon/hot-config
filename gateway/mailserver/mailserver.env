# General
OVERRIDE_HOSTNAME=mail.house-of-trae.com
LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=warn
TZ=Europe/London

# Postfix
POSTFIX_INET_PROTOCOLS=all

# TLS - using Caddy certs
SSL_TYPE=manual
SSL_CERT_PATH=/etc/caddy/certs/acme-v02.api.letsencrypt.org-directory/mail.house-of-trae.com/mail.house-of-trae.com.crt
SSL_KEY_PATH=/etc/caddy/certs/acme-v02.api.letsencrypt.org-directory/mail.house-of-trae.com/mail.house-of-trae.com.key

# Authentication
ENABLE_SASLAUTHD=0
ACCOUNT_PROVISIONER=FILE

# Security
ENABLE_FAIL2BAN=0
ENABLE_AMAVIS=0
ENABLE_SPAMASSASSIN=0
ENABLE_CLAMAV=1

# Spam filtering via Rspamd (modern replacement)
ENABLE_RSPAMD=1
ENABLE_RSPAMD_REDIS=1

# DKIM
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
ENABLE_POLICYD_SPF=0

# IMAP
ENABLE_DOVECOT=1

# Postscreen (basic bot protection)
ENABLE_POSTSCREEN=1
MESSAGE_SIZE_LIMIT=26214400
