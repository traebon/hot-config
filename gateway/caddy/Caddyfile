{
    email admin@house-of-trae.com
    acme_dns powerdns {
        server_url http://powerdns:8081
        server_id localhost
        api_token {env.PDNS_API_KEY}
    }
}
(crowdsec) {
    forward_auth crowdsec-bouncer:8083 {
        uri /api/v1/forwardAuth
        copy_headers X-Forwarded-For
    }
}
