{
    admin off
    order crowdsec first
    email admin@house-of-trae.com
    acme_dns powerdns {
        server_url http://powerdns:8081
        server_id localhost
        api_token {env.PDNS_API_KEY}
    }
    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 10
        }
        format json
    }
    crowdsec {
        api_url http://crowdsec:8080
        api_key {env.CROWDSEC_API_KEY}
        ticker_interval 10s
        appsec_url http://crowdsec:7422
    }
}
(crowdsec) {
    crowdsec
}
(compress) {
    encode zstd gzip
}
(secure_headers) {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }
}
# Keycloak SSO gate via oauth2-proxy — import into any app block to require
# a house-of-trae.com login before the upstream is reached. Cookie domain is
# .house-of-trae.com so one login covers every app that imports this.
(sso) {
    reverse_proxy /oauth2/* oauth2-proxy:4180 {
        header_up X-Real-IP {remote}
    }
    @not_oauth2 not path /oauth2/*
    forward_auth @not_oauth2 oauth2-proxy:4180 {
        uri /oauth2/auth
        header_up X-Real-IP {remote}
        copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Preferred-Username Authorization
        @error status 401
        handle_response @error {
            redir * /oauth2/start?rd={http.request.orig_uri} temporary
        }
    }
}
